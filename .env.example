# Runtime
DRY_RUN=true
POLL_INTERVAL_MS=5000
STATE_PATH=./data/state.json
LOG_LEVEL=INFO

# Symbols / markets
SYMBOLS=BTC
MAX_MARKETS=6

# Live permissions: default safe
ALLOW_LIVE_BUYS=false
ALLOW_LIVE_SELLS=false
ALLOW_CANCELS=true
AUTO_TAKE_PROFIT=false
AUTO_EXIT_NO_EDGE=false
AUTO_REDEEM=false

# Strategy hardening
ENTRY_CONFIRMATION_TICKS=3
EXIT_CONFIRMATION_TICKS=3
REENTRY_COOLDOWN_MS=120000
MIN_HOLD_MS=30000
MAKER_ORDER_TTL_MS=5000
MIN_EDGE=0.015
CANCEL_EDGE=0.004
MAX_QUOTE_AGE_MS=1500
MAX_POSITION_USD=10
MAX_OPEN_ORDERS_PER_MARKET=1

# Polymarket credentials, required only when live permissions are enabled
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
FUNDER_ADDRESS=
SIGNATURE_TYPE=
