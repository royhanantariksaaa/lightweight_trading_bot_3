# Runtime
DRY_RUN=true
POLL_INTERVAL_MS=5000
STATE_PATH=./data/state.json
RUST_LOG=info

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# Symbols / markets
# Defaults are intentionally limited to short-expiry crypto symbols.
SYMBOLS=BTC,ETH,SOL,XRP
MAX_MARKETS=24

# Live permissions: default safe
ALLOW_LIVE_BUYS=false
ALLOW_LIVE_SELLS=false
ALLOW_CANCELS=true
AUTO_TAKE_PROFIT=false
AUTO_EXIT_NO_EDGE=false
AUTO_REDEEM=false

# Last-1-minute 5m snipe scanner
ENABLE_LAST_MINUTE_5M_SNIPE=true
SNIPE_WINDOW_SECONDS=60
SNIPE_MIN_EDGE=0.02
SNIPE_MAX_PRICE=0.96
SNIPE_MIN_VOLUME_USD=250
SNIPE_MIN_LIQUIDITY_USD=50
SNIPE_LIQUIDITY_SCALE_USD=5000
SNIPE_MAX_POSITION_USD=5
SNIPE_MAX_SIGNALS=8

# Binance whale detector / market microstructure feed
ENABLE_WHALE_DETECTOR=true
# Empty WHALE_SYMBOLS falls back to SYMBOLS. Example: WHALE_SYMBOLS=BTC,ETH,SOL
WHALE_SYMBOLS=
WHALE_MINI_USD=5000
WHALE_USD=10000
WHALE_SUPER_USD=25000
WHALE_WALL_MIN_USD=25000
WHALE_TRACKING_WINDOW_MS=300000

# Strategy hardening
ENTRY_CONFIRMATION_TICKS=3
EXIT_CONFIRMATION_TICKS=3
REENTRY_COOLDOWN_MS=120000
MIN_HOLD_MS=30000
MAKER_ORDER_TTL_MS=5000
MIN_EDGE=0.015
CANCEL_EDGE=0.004
MAX_QUOTE_AGE_MS=1500
MAX_POSITION_USD=10
MAX_OPEN_ORDERS_PER_MARKET=1

# Polymarket CLOB V2 live trading.
# Live orders require DRY_RUN=false and ALLOW_LIVE_BUYS=true.
LIVE_MAX_ORDER_USD=5
LIVE_MIN_SECONDS_TO_EXPIRY=3
LIVE_ORDER_COOLDOWN_MS=20000
LIVE_ORDER_TYPE=GTC
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=
FUNDER_ADDRESS=
SIGNATURE_TYPE=
